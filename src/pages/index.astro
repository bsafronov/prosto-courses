---
import BaseLayout from "../layouts/BaseLayout.astro";
import { coursePath, getCourses } from "../lib/courses";

const courses = await getCourses();
---
<BaseLayout title="Course Catalog | Prosto.Courses">
  <section class="hero container">
    <p class="eyebrow">Course Catalog</p>
    <h1>Learn something useful, one Lesson at a time.</h1>
    <p>Short, focused Courses with clear progress and practical Knowledge Checks.</p>
  </section>
  <section class="container catalog" aria-labelledby="catalog-heading">
    <h2 id="catalog-heading">All courses</h2>
    <div class="grid">
      {courses.map((course) => (
        <article aria-labelledby={`course-${course.id}`}>
          <h3 id={`course-${course.id}`}><a href={coursePath(course.id)}>{course.data.title}</a></h3>
          <p>{course.data.summary}</p>
          <a class="learn-more" href={coursePath(course.id)} aria-label={`View ${course.data.title}`}>View Course <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: 4.5rem 3rem; }
  .hero h1 { max-width: 16ch; margin: .2rem 0 .8rem; font-size: clamp(2.2rem, 7vw, 4.5rem); line-height: 1.02; letter-spacing: -.055em; }
  .hero > p:last-child { max-width: 42rem; color: var(--color-muted); font-size: 1.1rem; }
  .catalog h2 { font-size: 1.5rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr)); gap: 1rem; }
  article { display: flex; min-height: 15rem; flex-direction: column; border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.35rem; background: var(--color-surface); box-shadow: var(--shadow); }
  h3 { margin: 0; font-size: 1.4rem; line-height: 1.3; }
  h3 a { color: var(--color-ink); text-decoration: none; }
  article p { color: var(--color-muted); }
  .learn-more { margin-top: auto; font-weight: 750; }
</style>
