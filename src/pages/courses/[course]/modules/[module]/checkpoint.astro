---
import { getCollection, render, type CollectionEntry } from "astro:content";
import CourseOutline from "../../../../../components/CourseOutline.astro";
import { semanticComponents } from "../../../../../components/semantic-components";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import {
  capstonePath,
  checkpointCourseSlug,
  checkpointModuleSlug,
  coursePath,
  getCourseTree,
  getLessonLinks,
  lessonPath,
  lessonSlug,
  modulePath,
  moduleSlug,
  type CourseModule,
  type CourseTree,
} from "../../../../../lib/courses";

export async function getStaticPaths() {
  const [courses, checkpoints] = await Promise.all([
    getCollection("courses"),
    getCollection("checkpoints"),
  ]);
  const paths = [];
  for (const checkpoint of checkpoints) {
    const courseSlug = checkpointCourseSlug(checkpoint);
    const course = courses.find((candidate) => candidate.id === courseSlug);
    if (!course) continue;
    paths.push({
      params: { course: courseSlug, module: checkpointModuleSlug(checkpoint) },
      props: { course, checkpoint, tree: await getCourseTree(courseSlug) },
    });
  }
  return paths;
}

type Props = {
  course: CollectionEntry<"courses">;
  checkpoint: CollectionEntry<"checkpoints">;
  tree: CourseTree;
};

const { course, checkpoint, tree }: Props = Astro.props;
const slug = checkpointModuleSlug(checkpoint);
const moduleIndex = tree.modules.findIndex(
  (candidate) => moduleSlug(candidate.module) === slug,
);
const currentModule = tree.modules[moduleIndex] as CourseModule;
const nextModule = tree.modules[moduleIndex + 1];
const previousLesson = currentModule.lessons.at(-1)!;
const lessons = tree.modules.flatMap((module) => module.lessons);
const lessonLinks = getLessonLinks(course.id, lessons);
const { Content } = await render(checkpoint);
---
<BaseLayout title={`${checkpoint.data.title} | ${course.data.title}`}>
  <div
    class="container assessment-shell"
    data-progress-root
    data-course-slug={course.id}
    data-lessons={JSON.stringify(lessonLinks)}
  >
    <nav class="course-navigation" aria-label="Навигация по курсу">
      <a class="overview-link" href={coursePath(course.id)}>О курсе</a>
      <CourseOutline
        courseSlug={course.id}
        tree={tree}
        lessonListLabel="Уроки в навигации курса"
        current={{ kind: "checkpoint", slug }}
      />
    </nav>
    <article class="assessment-content">
      <header>
        <p class="eyebrow">Проверка Модуля</p>
        <h1>{checkpoint.data.title}</h1>
        <p><a href={modulePath(course.id, slug)}>{currentModule.module.data.title}</a></p>
      </header>
      <div class="prose"><Content components={semanticComponents} /></div>
      <nav class="sequence" aria-label="Последовательность курса">
        <a href={lessonPath(course.id, lessonSlug(previousLesson))}>
          ← Последний урок: {previousLesson.data.title}
        </a>
        {nextModule
          ? <a href={modulePath(course.id, moduleSlug(nextModule.module))}>Перейти к следующему Модулю: {nextModule.module.data.title} →</a>
          : <a href={capstonePath(course.id)}>Перейти к итоговой работе →</a>}
      </nav>
    </article>
  </div>
  <script src="../../../../../scripts/progress.ts"></script>
</BaseLayout>

<style>
  .assessment-shell { display: grid; grid-template-columns: minmax(16rem, 21rem) minmax(0, 48rem); gap: 3rem; align-items: start; padding-top: 2rem; }
  .course-navigation { position: sticky; top: 1rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); padding: .8rem; }
  .overview-link { display: inline-block; margin: .2rem 0 .9rem; font-weight: 700; }
  .assessment-content { min-width: 0; }
  header { padding: 1.4rem 0 1.8rem; border-bottom: 1px solid var(--color-border); }
  h1 { margin: .15rem 0 .6rem; font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.08; letter-spacing: -.045em; }
  .prose { padding-top: 1rem; }
  .sequence { display: flex; justify-content: space-between; gap: 1rem; border-top: 1px solid var(--color-border); margin-top: 2.5rem; padding-top: 1.5rem; }
  .sequence a { font-weight: 750; }
  .sequence a:last-child { margin-left: auto; text-align: right; }
  @media (max-width: 52rem) {
    .assessment-shell { grid-template-columns: 1fr; gap: 1rem; }
    .course-navigation { position: static; }
  }
</style>
