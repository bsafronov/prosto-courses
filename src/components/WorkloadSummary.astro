---
interface Props {
  label: string;
  items: Array<{ label: string; value: string }>;
}

const { label, items } = Astro.props;
---
<dl class="workload" role="group" aria-label={label}>
  {items.map((item) => (
    <div>
      <dt>{item.label}</dt>
      <dd>{item.value}</dd>
    </div>
  ))}
</dl>

<style>
  .workload {
    display: flex;
    flex-wrap: wrap;
    gap: .7rem;
    margin: 1.5rem 0;
  }

  .workload div {
    min-width: 8.5rem;
    border: 1px solid var(--color-border);
    border-radius: .7rem;
    padding: .75rem .9rem;
    background: var(--color-surface);
  }

  dt { color: var(--color-muted); font-size: .78rem; font-weight: 750; }
  dd { margin: .15rem 0 0; font-size: 1.05rem; font-weight: 800; }

  @media (max-width: 30rem) {
    .workload { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .workload div { min-width: 0; }
  }
</style>
